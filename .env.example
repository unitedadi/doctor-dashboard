# Browser-visible API base URL.
# Development can use /api because Vite proxies it using VITE_API_PROXY_TARGET.
# Production/Preview on Vercel should be the real backend origin.
VITE_API_BASE=/api
VITE_DOCTOR_ID=doctor_sami_dev
VITE_DEFAULT_DOCTOR_ACCOUNT_ID=mp_sami
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Local development only. Vercel production does not use the Vite dev proxy.
VITE_API_PROXY_TARGET=https://api-prod.dardoc.com
